func leerOpcion(minimo: int, maximo: int): int {
    let opcion: int = -1;
    let valido: bool = false;
    while (!valido) {
        let entrada: string = input("👉 Elige una opción (${minimo}-${maximo}): ");
        opcion = int(entrada);
        if (opcion >= minimo && opcion <= maximo) {
            valido = true;
        } else {
            print("⚠️  Opción no válida. Por favor elige entre ${minimo} y ${maximo}.");
        }
    }
    return opcion;
}

func menuLetras(): void {
    let salir: bool = false;
    while (!salir) {
        mostrarMenuLetras();
        let opcion: int = leerOpcion(1, 4);
        switch (opcion) {
            case 1: letras.JugarBosqueLetras();
            case 2: letras.JugarCompletaPalabra();
            case 3: letras.JugarLetraIntrusa();
            case 4: salir = true;
        }
    }
}

func menuNumeros(): void {
    let salir: bool = false;
    while (!salir) {
        mostrarMenuNumeros();
        let opcion: int = leerOpcion(1, 4);
        switch (opcion) {
            case 1: numeros.OrdenaLosNumeros();
            case 2: numeros.MayorYMenor();
            case 3: numeros.JugarAdivinaNumero();
            case 4: salir = true;
        }
    }
}

func menuLogica(): void {
    let salir: bool = false;
    while (!salir) {
        mostrarMenuLogica();
        let opcion: int = leerOpcion(1, 2);
        switch (opcion) {
            case 1: logica.JugarCualSobra();
            case 2: salir = true;
        }
    }
}

func menuJuegos(): void {
    let salir: bool = false;
    while (!salir) {
        mostrarMenuJuegos();
        let opcion: int = leerOpcion(1, 2);
        switch (opcion) {
            case 1: queGrande();
            case 2: salir = true;
        }
    }
}

func mostrarDespedida(): void {
    print("");
    print("╔════════════════════════════════════════════╗");
    print("║           ¡Hasta la próxima! 👋            ║");
    print("║  Gracias por jugar con MINICOMPUTADORAS 🌟 ║");
    print("╚════════════════════════════════════════════╝");
}
mostrarBienvenida();

let ejecutando: bool = true;
while (ejecutando) {
    mostrarMenuPrincipal();
    let opcion: int = leerOpcion(1, 5);
    switch (opcion) {
        case 1: menuLetras();
        case 2: menuNumeros();
        case 3: menuLogica();
        case 4: menuJuegos();
        case 5: ejecutando = false;
    }
}

mostrarDespedida();